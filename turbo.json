{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "!.next/cache/**"]
    },
    "lint": {},
    "lint:fix": {
      "cache": false
    },
    "test": {},
    "test:e2e": {
      "cache": false
    }
  }
}
