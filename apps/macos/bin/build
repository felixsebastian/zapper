#!/usr/bin/env bash
set -euo pipefail

APP_NAME="Zapper"
APP_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
REPO_ROOT="$(cd "${APP_ROOT}/../.." && pwd)"
BUILD_DIR="${APP_ROOT}/build"
APP_DIR="${BUILD_DIR}/${APP_NAME}.app"
CONTENTS_DIR="${APP_DIR}/Contents"
MACOS_DIR="${CONTENTS_DIR}/MacOS"
RESOURCES_DIR="${CONTENTS_DIR}/Resources"
RUNTIME_DIR="${RESOURCES_DIR}/ZapperRuntime"
EXECUTABLE="${MACOS_DIR}/${APP_NAME}"
ARCH="${ARCH:-$(uname -m)}"
DEPLOYMENT_TARGET="${MACOSX_DEPLOYMENT_TARGET:-13.0}"
CODESIGN_IDENTITY="${CODESIGN_IDENTITY:--}"
CODESIGN_OPTIONS="${CODESIGN_OPTIONS:-}"
DEFAULT_ENTITLEMENTS="${APP_ROOT}/Signing/Zapper.entitlements"
CODESIGN_ENTITLEMENTS="${CODESIGN_ENTITLEMENTS:-}"
if [ -z "${CODESIGN_ENTITLEMENTS}" ] && [ -f "${DEFAULT_ENTITLEMENTS}" ]; then
  CODESIGN_ENTITLEMENTS="${DEFAULT_ENTITLEMENTS}"
fi
PACKAGE_ZAPPER_RUNTIME="${PACKAGE_ZAPPER_RUNTIME:-1}"

rm -rf "${APP_DIR}"
mkdir -p "${MACOS_DIR}" "${RESOURCES_DIR}"

cp "${APP_ROOT}/Resources/Info.plist" "${CONTENTS_DIR}/Info.plist"
find "${APP_ROOT}/Resources" -mindepth 1 -maxdepth 1 ! -name Info.plist -exec cp -R {} "${RESOURCES_DIR}/" \;

if [ "${PACKAGE_ZAPPER_RUNTIME}" = "1" ]; then
  NODE_PATH="${NODE_PATH:-$(command -v node || true)}"
  if [ -z "${NODE_PATH}" ] || [ ! -x "${NODE_PATH}" ]; then
    echo "node is required to package the bundled Zapper runtime" >&2
    exit 1
  fi
  if [ ! -f "${REPO_ROOT}/packages/cli/dist/index.js" ]; then
    echo "packages/cli/dist/index.js is missing; run pnpm --filter @mp-lb/zapper build first" >&2
    exit 1
  fi

  mkdir -p "${RUNTIME_DIR}/node/bin" "${RUNTIME_DIR}/cli"
  cp "${NODE_PATH}" "${RUNTIME_DIR}/node/bin/node"
  RUNTIME_PACKAGE_JSON="${RUNTIME_DIR}/cli/package.json" \
  SOURCE_PACKAGE_JSON="${REPO_ROOT}/packages/cli/package.json" \
  node <<'NODE'
const fs = require("node:fs");

const sourcePath = process.env.SOURCE_PACKAGE_JSON;
const runtimePath = process.env.RUNTIME_PACKAGE_JSON;
const source = JSON.parse(fs.readFileSync(sourcePath, "utf8"));
const runtime = {
  name: source.name,
  version: source.version,
  private: true,
  type: source.type,
  main: source.main,
  bin: source.bin,
  dependencies: source.dependencies || {},
  engines: source.engines || {},
};

fs.writeFileSync(runtimePath, `${JSON.stringify(runtime, null, 2)}\n`);
NODE
  cp -R "${REPO_ROOT}/packages/cli/dist" "${RUNTIME_DIR}/cli/dist"

  (
    cd "${RUNTIME_DIR}/cli"
    npm install \
      --omit=dev \
      --ignore-scripts \
      --no-audit \
      --no-fund \
      --package-lock=false
  )

  cat > "${RESOURCES_DIR}/zap" <<'ZAP_WRAPPER'
#!/usr/bin/env bash
set -euo pipefail

RESOURCE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUNTIME_DIR="${RESOURCE_DIR}/ZapperRuntime"
NODE_BIN="${RUNTIME_DIR}/node/bin/node"
CLI_ENTRY="${RUNTIME_DIR}/cli/dist/index.js"
PM2_ENTRY="${RUNTIME_DIR}/cli/node_modules/pm2/bin/pm2"

export ZAPPER_NODE="${NODE_BIN}"
export ZAPPER_PM2_JS="${PM2_ENTRY}"
export PATH="${PATH:-/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin}:${RUNTIME_DIR}/cli/node_modules/.bin:${RUNTIME_DIR}/node/bin"

exec "${NODE_BIN}" "${CLI_ENTRY}" "$@"
ZAP_WRAPPER
  chmod 755 "${RESOURCES_DIR}/zap" "${RUNTIME_DIR}/node/bin/node"
fi

xcrun --sdk macosx swiftc \
  -target "${ARCH}-apple-macos${DEPLOYMENT_TARGET}" \
  -parse-as-library \
  -O \
  -framework SwiftUI \
  -framework AppKit \
  -framework Combine \
  -o "${EXECUTABLE}" \
  "${APP_ROOT}"/Sources/Zapper/*.swift

codesign_args=(--force --sign "${CODESIGN_IDENTITY}")
if [ -n "${CODESIGN_OPTIONS}" ]; then
  codesign_args+=(--options "${CODESIGN_OPTIONS}")
fi
if [ "${CODESIGN_IDENTITY}" != "-" ]; then
  codesign_args+=(--timestamp)
fi
if [ -n "${CODESIGN_ENTITLEMENTS}" ]; then
  codesign_args+=(--entitlements "${CODESIGN_ENTITLEMENTS}")
fi

while IFS= read -r executable_file; do
  if file "${executable_file}" | grep -q "Mach-O"; then
    codesign "${codesign_args[@]}" "${executable_file}" >/dev/null
  fi
done < <(find "${RESOURCES_DIR}" -type f -perm -111)

codesign "${codesign_args[@]}" --deep "${APP_DIR}" >/dev/null
codesign --verify --deep --strict "${APP_DIR}"

echo "Built ${APP_DIR}"
